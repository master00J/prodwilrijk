# Kopieer naar .env.local en vul waarden in. Nooit committen.

# --- Supabase (verplicht) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site / CORS ---
NEXT_PUBLIC_SITE_URL=https://prodwilrijk.be

# --- SMTP (mailroutes) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Mail ontvangers ---
ORDER_EMAIL_TO=
KISTEN_REORDER_EMAIL_TO=
AIRTEC_DAILY_REPORT_RECIPIENTS=
AIRTEC_DAILY_REPORT_FROM=
# Rapport wanneer prio-lijnen van de PILS verdwijnen (default: prodwilrijk@foresco.eu)
GROTE_INPAK_PRIO_REPORT_TO=

# --- Cron / geheime API-hooks (verplicht in productie voor cron-routes) ---
CRON_SECRET=
AIRTEC_DAILY_REPORT_SECRET=
AIRTEC_KISTEN_REORDER_SECRET=
AIRTEC_MAIL_IMPORT_SECRET=
GROTE_INPAK_PILS_MAIL_IMPORT_SECRET=
GROTE_INPAK_PACKED_MAIL_IMPORT_SECRET=
GROTE_INPAK_KIST_MAIL_IMPORT_SECRET=
GROTE_INPAK_FORECAST_MAIL_IMPORT_SECRET=

# --- IMAP Airtec ---
AIRTEC_MAIL_HOST=
AIRTEC_MAIL_PORT=993
AIRTEC_MAIL_USER=
AIRTEC_MAIL_PASSWORD=
AIRTEC_MAILBOX=INBOX

# --- IMAP Grote Inpak (optioneel per mailbox) ---
GROTE_INPAK_PILS_MAIL_HOST=
GROTE_INPAK_PILS_MAIL_PORT=993
GROTE_INPAK_PILS_MAIL_USER=
GROTE_INPAK_PILS_MAIL_PASSWORD=
GROTE_INPAK_PILS_MAILBOX=INBOX
GROTE_INPAK_PACKED_MAIL_HOST=
GROTE_INPAK_PACKED_MAIL_USER=
GROTE_INPAK_PACKED_MAIL_PASSWORD=
GROTE_INPAK_PACKED_MAILBOX=INBOX

# --- AI (optioneel per feature) ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
OPENAI_LABEL_MODEL=
OPENAI_MAIL_MODEL=
# Instructievideo Grote Inpak (optioneel: stem nova/shimmer/alloy, model tts-1 of tts-1-hd)
OPENAI_INSTRUCTIE_TTS_VOICE=
OPENAI_INSTRUCTIE_TTS_MODEL=
ANTHROPIC_API_KEY=
GROTE_INPAK_VOICE_TRANSCRIBE_MODEL=
PERSONAL_ASSISTANT_MODEL=
PERSONAL_ASSISTANT_TRANSCRIBE_MODEL=
PERSONAL_ASSISTANT_REALTIME_MODEL=
PERSONAL_ASSISTANT_REALTIME_VOICE=
PERSONAL_ASSISTANT_REALTIME_TRANSCRIBE_MODEL=

# --- TV signage (optioneel: extra bescherming publieke read-API's) ---
# TV_DISPLAY_SECRET=
# NEXT_PUBLIC_TV_DISPLAY_TOKEN=   # zelfde waarde; voor /tv-display builds
