# Kopieer naar .env en vul in
EXPO_PUBLIC_API_BASE=https://prodwilrijk.be
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Wake word: standaard openWakeWord (geen key). Optioneel Picovoice:
# EXPO_PUBLIC_USE_PICOVOICE_WAKE=true
# EXPO_PUBLIC_PICOVOICE_ACCESS_KEY=
# EXPO_PUBLIC_OPENWAKEWORD_THRESHOLD=0.5
# Experimenteel offline wake word (crasht op Galaxy S24 — standaard uit):
# EXPO_PUBLIC_USE_OPENWAKEWORD_ON_ANDROID=true
