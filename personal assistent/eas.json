{
  "cli": {
    "version": ">= 13.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "22.11.0",
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://prodwilrijk.be",
        "NPM_CONFIG_PRODUCTION": "false",
        "EXPO_PUBLIC_PICOVOICE_ACCESS_KEY": ""
      },
      "prebuildCommand": "npx expo prebuild --platform android --clean",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.11.0",
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://prodwilrijk.be",
        "NPM_CONFIG_PRODUCTION": "false"
      },
      "prebuildCommand": "npx expo prebuild --platform android --clean",
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
