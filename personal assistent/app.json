{
  "expo": {
    "name": "Prodwilrijk Assistent",
    "slug": "prodwilrijk-personal-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "prodwilrijk-assistant",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a4b8c"
    },
    "android": {
      "package": "be.prodwilrijk.assistant",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a4b8c"
      },
      "permissions": [
        "INTERNET",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH_CONNECT"
      ]
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "De assistent gebruikt je microfoon (ook via oortjes) om vragen te stellen."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
