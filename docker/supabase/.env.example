############
# Prodwilrijk — Supabase self-hosted
#
# Setup:
#   cd docker/supabase
#   cp .env.example .env
#   ./generate-env.sh --update-env
#   ./up.sh
#
# Documentatie:
# https://supabase.com/docs/guides/self-hosting/docker
############

COMPOSE_FILE=docker-compose.yml

############
# Secrets — GENEREER via ./generate-env.sh (niet handmatig invullen)
############

POSTGRES_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
ANON_KEY=CHANGE_ME
SERVICE_ROLE_KEY=CHANGE_ME
SECRET_KEY_BASE=CHANGE_ME
VAULT_ENC_KEY=CHANGE_ME
PG_META_CRYPTO_KEY=CHANGE_ME
LOGFLARE_PUBLIC_ACCESS_TOKEN=CHANGE_ME
LOGFLARE_PRIVATE_ACCESS_TOKEN=CHANGE_ME
S3_PROTOCOL_ACCESS_KEY_ID=CHANGE_ME
S3_PROTOCOL_ACCESS_KEY_SECRET=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=CHANGE_ME

SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

############
# URLs — pas hostnames aan indien nodig
############

SUPABASE_PUBLIC_URL=https://api.prodwilrijk.be
API_EXTERNAL_URL=https://api.prodwilrijk.be
SITE_URL=https://prodwilrijk.be
ADDITIONAL_REDIRECT_URLS=https://prodwilrijk.be/*,https://prodwilrijk.be/**

############
# Database
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_TENANT_ID=prodwilrijk
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=5

############
# Studio
############

STUDIO_DEFAULT_ORGANIZATION=Prodwilrijk
STUDIO_DEFAULT_PROJECT=Prodwilrijk V2
OPENAI_API_KEY=

############
# Auth
############

JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# Gebruik bedrijfsmail of laat op supabase-mail (demo) staan voor tests
SMTP_ADMIN_EMAIL=admin@prodwilrijk.be
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=Prodwilrijk

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

############
# Storage
############

GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=prodwilrijk

############
# API / PostgREST
############

PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public
FUNCTIONS_VERIFY_JWT=false

############
# Analytics / gateway
############

DOCKER_SOCKET_LOCATION=/var/run/docker.sock
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
IMGPROXY_AUTO_WEBP=true
